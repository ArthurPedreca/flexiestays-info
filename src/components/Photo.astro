---
// A photo slot. Renders a real <img> when `src` is provided; otherwise a
// branded, clearly-decorative illustration (sun over waves) with the place
// name  so an image-less page reads as *designed*, never as a broken image.
// This matters because auto-generated pages will often ship before photography.
interface Props {
  src?: string;
  alt?: string;
  label?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
}
const { src, alt = '', label, class: cls = '', loading = 'lazy' } = Astro.props;
---
<figure class={`photo${src ? ' has-img' : ''} ${cls}`.trim()}>
  {src && <img src={src} alt={alt} loading={loading} decoding="async" />}
  {
    !src && (
      <div class="ph-art" aria-hidden="true">
        <svg viewBox="0 0 64 44" fill="none" aria-hidden="true">
          <circle cx="32" cy="16" r="8" fill="#E3B562" />
          <path d="M4 30c4 0 4 3 8 3s4-3 8-3 4 3 8 3 4-3 8-3 4 3 8 3 4-3 8-3" stroke="#FCFAF5" stroke-width="2" stroke-linecap="round" opacity=".9" />
          <path d="M4 37c4 0 4 3 8 3s4-3 8-3 4 3 8 3 4-3 8-3 4 3 8 3 4-3 8-3" stroke="#FCFAF5" stroke-width="2" stroke-linecap="round" opacity=".5" />
        </svg>
        {label && <span class="ph-label">{label}</span>}
      </div>
    )
  }
</figure>
