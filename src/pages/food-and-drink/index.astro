---
import { getEntry, getCollection, render } from 'astro:content';
import HubLayout from '../../layouts/HubLayout.astro';

const hub = await getEntry('hubs', 'food-and-drink');
if (!hub) throw new Error('Missing hub content: src/content/hubs/food-and-drink.md');
const { Content } = await render(hub);

const listings = (
  await getCollection('listings', (e) => !e.data.draft && ['restaurant', 'pub-bar', 'cafe'].includes(e.data.category))
).map((e) => ({ id: e.id, data: e.data }));

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Food & Drink', url: '/food-and-drink' },
];
---
<HubLayout hub={hub} path="/food-and-drink" breadcrumbs={breadcrumbs} listings={listings}>
  <Content />
</HubLayout>
